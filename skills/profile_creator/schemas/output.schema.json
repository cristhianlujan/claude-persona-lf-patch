{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LF Profile Creator Output",
  "type": "object",
  "required": [
    "status",
    "profile_pack_id",
    "source_authority",
    "deliverable_created",
    "files_created",
    "evidence_map",
    "blocking_codes",
    "next_gate"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "PROFILE_PACK_CREATED",
        "RETURN_TO_ORCHESTRATOR",
        "RETURN_TO_WORKER_FOR_SELF_REPAIR",
        "BLOCK_PIPELINE"
      ]
    },
    "profile_pack_id": { "type": "string" },
    "source_authority": { "type": "string" },
    "deliverable_created": { "type": "boolean" },
    "files_created": { "type": "array", "items": { "type": "string" } },
    "evidence_map": { "type": "object" },
    "blocking_codes": { "type": "array", "items": { "type": "string" } },
    "next_gate": { "type": "string" }
  }
}
