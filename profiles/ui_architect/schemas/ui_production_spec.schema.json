{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI Architect Production UI Spec",
  "type": "object",
  "required": ["worker", "output_type", "deliverable_created", "score", "handoff_to_next", "self_verdict"],
  "properties": {
    "worker": {"type": "string"},
    "output_type": {"type": "string"},
    "deliverable_created": {
      "type": "object",
      "required": [
        "screen_definition",
        "component_tree",
        "layout_grid",
        "visual_hierarchy",
        "state_map",
        "token_map",
        "spacing_typography",
        "density_rules",
        "risk_controls",
        "prompt_constraints",
        "supported_visual_decisions",
        "unsupported_visual_additions",
        "blocking_handoff"
      ],
      "properties": {
        "screen_definition": {"type": "object"},
        "component_tree": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["zone_id", "component_id", "component_type", "role", "content", "visual_priority", "color_tokens", "typography", "spacing", "state", "allowed_variants", "blocked_variants"]
          }
        },
        "layout_grid": {"type": "object"},
        "visual_hierarchy": {"type": "array"},
        "state_map": {"type": "object"},
        "token_map": {"type": "object"},
        "spacing_typography": {"type": "object"},
        "density_rules": {"type": "array"},
        "risk_controls": {"type": "array"},
        "prompt_constraints": {"type": "array"},
        "supported_visual_decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["decision", "source", "evidence", "composer_instruction"],
            "properties": {
              "decision": {"type": "string"},
              "source": {"type": "string"},
              "evidence": {"type": "string"},
              "composer_instruction": {"type": "string"}
            }
          }
        },
        "unsupported_visual_additions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["addition", "why_unsupported", "judge_block_if_seen"],
            "properties": {
              "addition": {"type": "string"},
              "why_unsupported": {"type": "string"},
              "judge_block_if_seen": {"type": "string"}
            }
          }
        },
        "blocking_handoff": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["risk", "target", "required_action", "blocking_code"],
            "properties": {
              "risk": {"type": "string"},
              "target": {"type": "string"},
              "required_action": {"type": "string"},
              "blocking_code": {"type": "string"}
            }
          }
        },
        "visual_output_requirements": {
          "type": "object",
          "properties": {
            "layout_preservation": {"type": "array"},
            "hierarchy_preservation": {"type": "array"},
            "legibility_preservation": {"type": "array"},
            "state_preservation": {"type": "array"},
            "composition_constraints": {"type": "array"},
            "artifact_constraints": {"type": "array"},
            "acceptance_criteria": {"type": "array"}
          }
        }
      }
    },
    "score": {"type": "object"},
    "handoff_to_next": {"type": "object"},
    "self_verdict": {"type": "string"}
  }
}
