{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SafeAIGovernanceCardOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "source_of_truth", "official_skill_or_protocol", "allowed_actor", "allowed_operation", "decision", "runtime_enabled", "automatic_impact", "validated", "vigente", "approved"],
  "properties": {
    "mode": {"enum": ["SAFE_READ_ONLY", "ROUTE_TO_SKILL", "WAIT_FOR_PROTOCOL", "BLOCKED_UNAUTHORIZED_ACTION", "NEEDS_USER_DECISION", "INCIDENT_CONTAINMENT", "VERIFY_ONLY"]},
    "source_of_truth": {"type": "string"},
    "official_skill_or_protocol": {"type": "string"},
    "allowed_actor": {"type": "string"},
    "allowed_operation": {"type": "string"},
    "decision": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "runtime_enabled": {"const": false},
    "automatic_impact": {"const": "BLOCKED"},
    "validated": {"const": false},
    "vigente": {"const": false},
    "approved": {"const": false}
  }
}
