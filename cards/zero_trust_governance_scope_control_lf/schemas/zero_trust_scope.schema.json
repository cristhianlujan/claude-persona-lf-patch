{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ZeroTrustGovernanceScopeOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode", "source_of_truth", "explicit_authorization", "excluded_scope", "assistant_role", "decision", "runtime_enabled", "automatic_impact", "validated", "vigente", "approved"],
  "properties": {
    "mode": {"enum": ["SCOPE_CONFIRMED", "SCOPE_REDUCED", "RETURN_TO_ROUTER", "WAIT_FOR_SKILL_REQUEST", "BLOCKED_SCOPE_BYPASS", "BLOCKED_EXCESSIVE_AGENCY", "BLOCKED_UNAUTHORIZED_WRITE", "READY_FOR_READ_ONLY_DESIGN"]},
    "source_of_truth": {"type": "string"},
    "explicit_authorization": {"type": "string"},
    "excluded_scope": {"type": "string"},
    "assistant_role": {"type": "string"},
    "decision": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "runtime_enabled": {"const": false},
    "automatic_impact": {"const": "BLOCKED"},
    "validated": {"const": false},
    "vigente": {"const": false},
    "approved": {"const": false}
  }
}
